# Copy this file to .env and fill in real values. Never commit .env itself.

# Sightengine dashboard -> API credentials (used for image/video AI + deepfake detection)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# huggingface.co -> Settings -> Access Tokens (used for text/audio detection + image captioning)
HUGGINGFACE_API_KEY=

# Neon (or any Postgres) connection string, used by the Trending feed. Must include sslmode=require.
DATABASE_URL=

# Any long random string you choose yourself (e.g. `openssl rand -hex 24`).
# Sent as the x-admin-secret header to unlock the /admin dashboard and /admin/* routes.
ADMIN_SECRET=

PORT=3000
